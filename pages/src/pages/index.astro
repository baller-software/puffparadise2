---
import BaseLayout from '../layouts/BaseLayout.astro';

const valueProps = [
  {
    icon: 'fire',
    color: 'amber',
    title: 'Hottest Flavors in Stock',
    description: 'We always keep the latest and most popular vape flavors stocked and ready — no waiting for what\'s trending.',
  },
  {
    icon: 'star',
    color: 'blue',
    title: 'Top Brands & Wide Selection',
    description: 'Shop the industry\'s leading brands curated for quality and variety. If it\'s popular, we carry it.',
  },
  {
    icon: 'face-smile',
    color: 'emerald',
    title: 'Great Vibes & Expert Staff',
    description: 'Our friendly, knowledgeable team creates a welcoming atmosphere and helps you find exactly what you need.',
  },
  {
    icon: 'clock',
    color: 'sky',
    title: 'Open 9 AM – 10 PM Daily',
    description: 'Extended hours seven days a week so we\'re here when you need us — morning, afternoon, or evening.',
  },
];

const services = [
  {
    title: 'Vapes & E-Cigarettes',
    description: 'The latest vaping devices and flavors, including the hottest Lost Mary products. We keep our shelves stocked with what\'s new and what\'s popular.',
    colorClass: 'text-purple-600',
    bgClass: 'bg-purple-100',
  },
  {
    title: 'Kratom Products',
    description: 'Quality kratom for your wellness needs. Our knowledgeable staff can help you understand the options and find the right fit.',
    colorClass: 'text-emerald-600',
    bgClass: 'bg-emerald-100',
  },
  {
    title: 'Hemp & CBD',
    description: 'A curated selection of hemp-derived CBD products from trusted brands. Explore natural wellness solutions with guidance from our team.',
    colorClass: 'text-green-600',
    bgClass: 'bg-green-100',
  },
  {
    title: 'Smoking Supplies',
    description: 'Pipes, papers, wraps, lighters, and all the accessories you need. Everything in one convenient location.',
    colorClass: 'text-orange-600',
    bgClass: 'bg-orange-100',
  },
  {
    title: 'Top Industry Brands',
    description: 'We handpick the most respected and popular brands in the industry so you can shop with confidence every visit.',
    colorClass: 'text-blue-600',
    bgClass: 'bg-blue-100',
  },
  {
    title: 'Expert Guidance',
    description: 'Our knowledgeable staff are always ready to answer questions and point you toward the products that best fit your needs.',
    colorClass: 'text-sky-600',
    bgClass: 'bg-sky-100',
  },
];

const serviceIconSVGs = {
  'Vapes & E-Cigarettes': `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
  'Kratom Products': `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />`,
  'Hemp & CBD': `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
  'Smoking Supplies': `<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z" />`,
  'Top Industry Brands': `<path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />`,
  'Expert Guidance': `<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />`,
};
---

<BaseLayout title="Home" description="Puff Paradise — Forney's go-to smoke and vape shop. The hottest flavors, top brands, and great vibes at 16383 FM 548, Suite 112.">

  <!-- HERO SECTION -->
  <section
    class="relative flex items-center"
    style="min-height: 85vh; background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 40%, #172554 70%, #0f172a 100%);"
    aria-label="Hero"
  >
    <!-- Decorative gradient overlay -->
    <div class="absolute inset-0 opacity-40" style="background: radial-gradient(ellipse at 30% 50%, #2563eb33 0%, transparent 60%), radial-gradient(ellipse at 70% 30%, #7c3aed22 0%, transparent 50%);"></div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 py-20 sm:py-32">
      <div class="max-w-2xl">
        <!-- Status Badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border px-4 py-1.5" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(8px); border-color: rgba(255,255,255,0.2);">
          <span class="h-2 w-2 rounded-full bg-emerald-400 animate-pulse" aria-hidden="true"></span>
          <span class="text-xs font-medium text-slate-200 uppercase tracking-wider">Open Daily 9 AM – 10 PM</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Your Neighborhood<br />
          <span style="color: var(--color-primary-light);">Smoke & Vape</span><br />
          Shop in Forney
        </h1>

        <!-- Supporting text -->
        <p class="text-lg sm:text-xl text-slate-300 leading-relaxed mb-10 max-w-xl">
          We carry the hottest flavors, top brands, and the widest selection — with knowledgeable staff and great vibes every time you walk in.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 rounded-lg px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl"
            style="background-color: var(--color-primary); min-height: 48px;"
          >
            Get in Touch
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="tel:+19369001762"
            class="inline-flex items-center justify-center gap-2 rounded-lg border-2 px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:-translate-y-0.5"
            style="border-color: rgba(255,255,255,0.3); min-height: 48px;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            Call (936) 900-1762
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS / INFO BAR (floating over hero bottom) -->
  <div class="relative -mt-12 z-10 mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 rounded-2xl p-6 shadow-xl border" style="background-color: var(--color-background); border-color: var(--color-border);">
      {[
        { label: 'Hours', value: '9 AM – 10 PM', note: 'Open Daily' },
        { label: 'Location', value: 'Forney, TX', note: 'FM 548, Suite 112' },
        { label: 'Phone', value: '(936) 900-1762', note: 'Call anytime' },
        { label: 'Products', value: '100s of Flavors', note: 'Always stocked' },
      ].map(stat => (
        <div class="text-center px-2">
          <div class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--color-primary);">{stat.label}</div>
          <div class="text-base sm:text-lg font-bold" style="color: var(--color-text-primary);">{stat.value}</div>
          <div class="text-xs" style="color: var(--color-text-secondary);">{stat.note}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- VALUE PROPOSITIONS -->
  <section class="py-20 sm:py-24 mt-8" style="background-color: var(--color-background);" aria-label="Why choose us">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <!-- Section header -->
      <div class="text-center mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: var(--color-primary);">Why Puff Paradise</p>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--color-text-primary);">The Forney Favorite</h2>
        <p class="mx-auto max-w-2xl text-base" style="color: var(--color-text-secondary);">
          From unbeatable selection to extended hours, here's what sets us apart from the rest.
        </p>
      </div>

      <!-- Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {valueProps.map((vp, i) => {
          const colors = {
            amber: { bg: '#fef3c7', text: '#d97706', darkBg: 'rgba(217,119,6,0.2)' },
            blue: { bg: '#dbeafe', text: '#2563eb', darkBg: 'rgba(37,99,235,0.2)' },
            emerald: { bg: '#d1fae5', text: '#059669', darkBg: 'rgba(5,150,105,0.2)' },
            sky: { bg: '#e0f2fe', text: '#0284c7', darkBg: 'rgba(2,132,199,0.2)' },
          };
          const c = colors[vp.color];

          const iconPaths = {
            fire: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />`,
            star: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />`,
            'face-smile': `<path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />`,
            clock: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />`,
          };

          return (
            <div
              class="group rounded-2xl border p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg cursor-default"
              style={`background-color: var(--color-background); border-color: var(--color-border);`}
            >
              <div
                class="h-12 w-12 rounded-xl flex items-center justify-center mb-4 transition-transform duration-300 group-hover:scale-110"
                style={`background-color: ${c.bg}; color: ${c.text};`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
                  <Fragment set:html={iconPaths[vp.icon]} />
                </svg>
              </div>
              <h3 class="text-base font-semibold mb-2" style="color: var(--color-text-primary);">{vp.title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">{vp.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- SERVICES SECTION -->
  <section class="py-20 sm:py-24" style="background-color: var(--color-surface);" aria-label="Our products and services">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <!-- Section header -->
      <div class="text-center mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: var(--color-primary);">What We Carry</p>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--color-text-primary);">Products & Services</h2>
        <p class="mx-auto max-w-2xl text-base" style="color: var(--color-text-secondary);">
          From the latest vape flavors to smoking accessories and wellness products — all under one roof in Forney.
        </p>
      </div>

      <!-- Service Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <div
            class="group rounded-2xl border p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg cursor-default overflow-hidden"
            style="background-color: var(--color-background); border-color: var(--color-border);"
          >
            <div
              class={`h-10 w-10 rounded-xl flex items-center justify-center mb-4 transition-transform duration-300 group-hover:scale-110 ${service.bgClass} ${service.colorClass}`}
              aria-hidden="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
                <Fragment set:html={serviceIconSVGs[service.title]} />
              </svg>
            </div>
            <h3 class="text-base font-semibold mb-2" style="color: var(--color-text-primary);">{service.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS SECTION -->
  <section class="py-20 sm:py-24" style="background-color: var(--color-background);" aria-label="Customer testimonials">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: var(--color-primary);">What Customers Say</p>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--color-text-primary);">The Community Loves Us</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            quote: "That's why you come to Puff Paradise Smoke and Vape Shop — we keep the hottest flavors in stock and ready for you!",
            author: 'Google Review',
          },
          {
            quote: "Come check out Puff Paradise Smoke and experience your new favorite spot for all things. Huge selection, top brands, and unbeatable vibes.",
            author: 'Facebook',
          },
          {
            quote: "Great vibes in Forney, TX. Amazing atmosphere and enjoyable moments every visit. Truly a community gem.",
            author: 'Google Review',
          },
        ].map(testimonial => (
          <div
            class="relative rounded-2xl border p-6"
            style="background-color: var(--color-surface); border-color: var(--color-border);"
          >
            <!-- Decorative quote mark -->
            <svg class="absolute top-4 right-4 h-10 w-10 opacity-10" style="color: var(--color-primary);" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <!-- Stars -->
            <div class="flex gap-1 mb-4" aria-label="5 stars">
              {[...Array(5)].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 text-amber-400" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
                </svg>
              ))}
            </div>
            <blockquote class="text-sm leading-relaxed mb-4" style="color: var(--color-text-primary); line-height: 1.7;">
              "{testimonial.quote}"
            </blockquote>
            <footer class="text-xs font-medium" style="color: var(--color-text-secondary);">
              — {testimonial.author}
            </footer>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section
    class="py-20 sm:py-24 relative overflow-hidden"
    style="background: linear-gradient(135deg, rgba(37,99,235,0.95) 0%, rgba(29,78,216,0.92) 100%), linear-gradient(135deg, #0f172a 0%, #172554 100%);"
    aria-label="Call to action"
  >
    <div class="relative mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Ready to Visit Puff Paradise?
      </h2>
      <p class="text-lg text-blue-100 mb-10 max-w-xl mx-auto">
        Stop by our store on FM 548 in Forney, TX. We're open daily from 9 AM to 10 PM and ready to help you find exactly what you're looking for.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-8 py-4 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl"
          style="color: var(--color-primary); min-height: 48px;"
        >
          Send a Message
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href="tel:+19369001762"
          class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/30 px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:-translate-y-0.5"
          style="min-height: 48px;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          Call (936) 900-1762
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
