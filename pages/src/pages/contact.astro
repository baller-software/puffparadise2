---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Puff Paradise. Visit us at 16383 FM 548, Suite 112, Forney, TX or call (936) 900-1762. Open daily 9 AM – 10 PM."
>

  <!-- PAGE HERO -->
  <section
    class="relative py-20 sm:py-28 flex items-center overflow-hidden"
    style="background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 40%, #172554 70%, #0f172a 100%);"
    aria-label="Contact page hero"
  >
    <!-- Background image -->
    <img
      src="https://picsum.photos/seed/puffparadise-contact-hero/1920/800"
      alt=""
      class="absolute inset-0 h-full w-full object-cover opacity-25"
      loading="eager"
      aria-hidden="true"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,23,42,0.85) 0%, rgba(30,27,75,0.75) 40%, rgba(23,37,84,0.80) 70%, rgba(15,23,42,0.90) 100%);"></div>
    <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at 40% 60%, #2563eb33 0%, transparent 60%);"></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--color-primary-light);">Get In Touch</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">Contact Puff Paradise</h1>
      <p class="text-lg text-slate-300 max-w-xl mx-auto">
        Have a question? Want to know if we carry something specific? Reach out — we'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- CONTACT INFO CARDS (floating) -->
  <div class="relative -mt-10 z-10 mx-auto max-w-5xl px-4 sm:px-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <!-- Phone -->
      <a
        href="tel:+19369001762"
        class="group flex items-start gap-4 rounded-2xl border p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg no-underline"
        style="background-color: var(--color-background); border-color: var(--color-border);"
      >
        <div
          class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl transition-transform duration-300 group-hover:scale-110"
          style="background-color: color-mix(in srgb, var(--color-primary) 10%, transparent); color: var(--color-primary);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--color-text-secondary);">Phone</p>
          <p class="text-base font-semibold" style="color: var(--color-text-primary);">(936) 900-1762</p>
          <p class="text-xs mt-0.5" style="color: var(--color-text-secondary);">Tap to call</p>
        </div>
      </a>

      <!-- Location -->
      <a
        href="https://maps.google.com/?q=16383+FM+548+Suite+112+Forney+TX+75216"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-start gap-4 rounded-2xl border p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg no-underline"
        style="background-color: var(--color-background); border-color: var(--color-border);"
      >
        <div
          class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl transition-transform duration-300 group-hover:scale-110"
          style="background-color: color-mix(in srgb, #10b981 10%, transparent); color: #10b981;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--color-text-secondary);">Location</p>
          <p class="text-sm font-semibold leading-snug" style="color: var(--color-text-primary);">16383 FM 548, Suite 112<br />Forney, TX 75216</p>
          <p class="text-xs mt-0.5" style="color: var(--color-text-secondary);">Get directions</p>
        </div>
      </a>

      <!-- Hours -->
      <div
        class="flex items-start gap-4 rounded-2xl border p-6"
        style="background-color: var(--color-background); border-color: var(--color-border);"
      >
        <div
          class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl"
          style="background-color: color-mix(in srgb, #f59e0b 10%, transparent); color: #f59e0b;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--color-text-secondary);">Hours</p>
          <p class="text-base font-semibold" style="color: var(--color-text-primary);">9 AM – 10 PM</p>
          <p class="text-xs mt-0.5 flex items-center gap-1.5" style="color: var(--color-text-secondary);">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 inline-block animate-pulse"></span>
            Open daily, every day
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- MAIN CONTACT SECTION: Form + Info -->
  <section class="py-20 sm:py-24 mt-6" style="background-color: var(--color-background);" aria-label="Contact form and information">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Contact Form (3/5) -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--color-text-primary);">Send Us a Message</h2>
          <p class="text-sm mb-8" style="color: var(--color-text-secondary);">
            Fill out the form below and we'll get back to you as soon as we can.
            Required fields are marked with <span style="color: var(--color-error);">*</span>.
          </p>
          <ContactForm />
        </div>

        <!-- Additional Info (2/5) -->
        <aside class="lg:col-span-2" aria-label="Additional contact information">
          <div class="sticky top-24 space-y-6">
            <!-- Social links -->
            <div class="rounded-2xl border p-6" style="background-color: var(--color-surface); border-color: var(--color-border);">
              <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-primary);">Find Us Online</h3>
              <div class="flex flex-col gap-3">
                {[
                  { name: 'Instagram', handle: '@puffparadiseforney', url: 'https://www.instagram.com/puffparadiseforney/' },
                  { name: 'Facebook', handle: 'Puff Paradise', url: 'https://www.facebook.com/61587326453733/' },
                  { name: 'TikTok', handle: '@puffparadiseforney', url: 'https://www.tiktok.com/@puffparadiseforney' },
                ].map(social => (
                  <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-3 text-sm no-underline transition-colors duration-150 hover:text-primary"
                    style="color: var(--color-text-secondary);"
                  >
                    <div class="h-8 w-8 rounded-lg flex items-center justify-center shrink-0" style="background-color: var(--color-border);">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                      </svg>
                    </div>
                    <div>
                      <div class="font-medium" style="color: var(--color-text-primary);">{social.name}</div>
                      <div class="text-xs">{social.handle}</div>
                    </div>
                  </a>
                ))}
              </div>
            </div>

            <!-- Note about age -->
            <div class="rounded-xl border p-4" style="background-color: color-mix(in srgb, var(--color-warning) 8%, transparent); border-color: color-mix(in srgb, var(--color-warning) 25%, transparent);">
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 shrink-0 mt-0.5" style="color: var(--color-warning);" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
                </svg>
                <p class="text-xs leading-relaxed" style="color: var(--color-text-primary);">
                  <strong>Age requirement:</strong> You must be 21+ to purchase tobacco, vape, and hemp products in Texas. Please bring a valid photo ID when visiting.
                </p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- VISIT / STOREFRONT SECTION -->
  <section class="py-16 sm:py-20" style="background-color: var(--color-surface);" aria-label="Visit our store">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
        <!-- Storefront image -->
        <div class="rounded-2xl overflow-hidden border shadow-lg" style="border-color: var(--color-border);">
          <img
            src="https://picsum.photos/seed/puffparadise-storefront/1200/800"
            alt="Puff Paradise storefront in Forney, TX"
            class="w-full h-64 sm:h-80 lg:h-96 object-cover"
            loading="lazy"
          />
        </div>

        <!-- Copy -->
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider mb-3" style="color: var(--color-primary);">Visit the Shop</p>
          <h2 class="text-3xl sm:text-4xl font-bold mb-5" style="color: var(--color-text-primary);">
            Come See Us in Person
          </h2>
          <p class="text-base leading-relaxed mb-6" style="color: var(--color-text-secondary);">
            Drop in anytime from 9 AM to 10 PM, every day of the week. We're conveniently located on FM 548 in Forney, ready to help you find exactly what you're looking for.
          </p>

          <a
            href="https://maps.google.com/?q=16383+FM+548+Suite+112+Forney+TX+75216"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg no-underline"
            style="background-color: var(--color-primary); min-height: 44px;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            Get Directions
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
