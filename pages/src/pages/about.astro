---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Us"
  description="Learn the story behind Puff Paradise — Forney's hometown smoke and vape shop. Our mission, values, and community commitment."
>

  <!-- PAGE HERO -->
  <section
    class="relative py-20 sm:py-28 flex items-center"
    style="background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 40%, #172554 70%, #0f172a 100%);"
    aria-label="About page hero"
  >
    <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at 60% 40%, #2563eb33 0%, transparent 60%);"></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--color-primary-light);">Our Story</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">About Puff Paradise</h1>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">
        Born in Forney, built for the community. We're more than a smoke shop — we're your neighborhood's favorite spot.
      </p>
    </div>
  </section>

  <!-- COMPANY STORY SECTION -->
  <section class="py-20 sm:py-24" style="background-color: var(--color-background);" aria-labelledby="story-heading">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Story Content -->
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider mb-3" style="color: var(--color-primary);">Our Background</p>
          <h2 id="story-heading" class="text-3xl sm:text-4xl font-bold mb-6" style="color: var(--color-text-primary);">
            How Puff Paradise Came to Be
          </h2>

          <div class="space-y-5 text-base leading-relaxed" style="color: var(--color-text-secondary);">
            <p>
              Puff Paradise opened at 16383 FM 548, Suite 112 in Forney, TX with one clear goal: bring quality vape and smoke products to the local community at fair prices, in a store where customers actually enjoy spending time.
            </p>
            <p>
              From day one, we focused on keeping the most popular flavors in stock — because nothing is more frustrating than showing up and finding empty shelves. We listen to our customers, track what's trending, and stock what people actually want.
            </p>
            <p>
              We've grown to carry top brands in vaping, smoking accessories, kratom, and hemp/CBD products. Our team takes pride in staying knowledgeable so we can genuinely help customers find the right products for their needs — not just push whatever's on the shelf.
            </p>
            <p>
              Today, Puff Paradise is a community staple in Forney. We're actively growing our team with motivated, reliable people who share our passion for great customer service.
            </p>
          </div>
        </div>

        <!-- Story Highlights -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { label: 'Location', value: 'Forney, TX', sub: 'FM 548, Suite 112' },
            { label: 'Hours', value: '9 AM – 10 PM', sub: 'Open every day' },
            { label: 'Products', value: 'Vapes & More', sub: 'Kratom, Hemp, Supplies' },
            { label: 'Team', value: 'Growing', sub: 'Now hiring' },
          ].map(item => (
            <div
              class="rounded-2xl border p-5 text-center"
              style="background-color: var(--color-surface); border-color: var(--color-border);"
            >
              <div class="text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--color-primary);">{item.label}</div>
              <div class="text-lg font-bold mb-1" style="color: var(--color-text-primary);">{item.value}</div>
              <div class="text-xs" style="color: var(--color-text-secondary);">{item.sub}</div>
            </div>
          ))}
          <!-- Community badge spanning full width -->
          <div
            class="col-span-2 rounded-2xl border p-5 flex items-center gap-4"
            style="background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 8%, transparent), color-mix(in srgb, var(--color-primary) 4%, transparent)); border-color: color-mix(in srgb, var(--color-primary) 20%, transparent);"
          >
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl" style="background-color: var(--color-primary);">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 text-white" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-semibold" style="color: var(--color-text-primary);">Proudly Community-Rooted</div>
              <div class="text-xs mt-0.5" style="color: var(--color-text-secondary);">Active on social media, engaged with Forney neighbors, and committed to local customer service.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION SECTION -->
  <section class="py-20 sm:py-24" style="background-color: var(--color-surface);" aria-labelledby="mission-heading">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider mb-3" style="color: var(--color-primary);">Our Mission</p>
        <h2 id="mission-heading" class="text-3xl sm:text-4xl font-bold mb-8" style="color: var(--color-text-primary);">
          Why We Do What We Do
        </h2>

        <!-- Mission statement — visually emphasized -->
        <blockquote
          class="relative rounded-2xl border-l-4 px-8 py-8 text-left mb-12"
          style="border-left-color: var(--color-primary); background-color: var(--color-background);"
        >
          <p class="text-xl sm:text-2xl font-semibold leading-relaxed" style="color: var(--color-text-primary);">
            "To be Forney's go-to destination for vaping and smoking products — offering the widest selection, the hottest flavors, and the most knowledgeable, friendly service in the area."
          </p>
          <footer class="mt-4 text-sm font-medium" style="color: var(--color-primary);">— Puff Paradise Mission Statement</footer>
        </blockquote>

        <!-- Supporting values -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-left">
          {[
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
              title: 'Quality First',
              description: 'We carry only trusted brands and quality products. Your satisfaction — and safety — matter most to us.',
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />`,
              title: 'Expert Knowledge',
              description: 'Our team stays current so we can give you real, helpful guidance — not just sales pitches.',
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />`,
              title: 'Community Spirit',
              description: 'We\'re neighbors too. Forney is our community, and we\'re proud to serve and support it every day.',
            },
          ].map(value => (
            <div
              class="rounded-2xl border p-6"
              style="background-color: var(--color-background); border-color: var(--color-border);"
            >
              <div
                class="h-10 w-10 rounded-xl flex items-center justify-center mb-4"
                style="background-color: color-mix(in srgb, var(--color-primary) 10%, transparent); color: var(--color-primary);"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5" aria-hidden="true">
                  <Fragment set:html={value.icon} />
                </svg>
              </div>
              <h3 class="text-sm font-semibold mb-2" style="color: var(--color-text-primary);">{value.title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section
    class="py-20 sm:py-24 relative overflow-hidden"
    style="background: linear-gradient(135deg, rgba(37,99,235,0.95) 0%, rgba(29,78,216,0.92) 100%);"
    aria-label="Visit us call to action"
  >
    <div class="relative mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Come See Us in Forney</h2>
      <p class="text-lg text-blue-100 mb-10 max-w-xl mx-auto">
        We're open daily from 9 AM to 10 PM at 16383 FM 548, Suite 112. Stop by and experience the Puff Paradise difference.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-8 py-4 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl"
          style="color: var(--color-primary); min-height: 48px;"
        >
          Contact Us
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href="tel:+19369001762"
          class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/30 px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:-translate-y-0.5"
          style="min-height: 48px;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          Call (936) 900-1762
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
