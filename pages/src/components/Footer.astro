---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentYear = new Date().getFullYear();
---

<footer style="background-color: var(--color-surface); border-top: 1px solid var(--color-border);">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand Column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={`${base}/`} class="flex items-center gap-3 no-underline mb-4" aria-label="Puff Paradise Home">
          <img
            src={`${base}/puff-logo.png`}
            alt=""
            class="h-10 w-10 shrink-0"
            width="40"
            height="40"
          />
          <div>
            <div class="text-sm font-bold leading-tight" style="color: var(--color-text-primary);">Puff Paradise</div>
            <div class="text-[11px] font-medium uppercase tracking-wider" style="color: var(--color-text-secondary);">Smoke & Vape</div>
          </div>
        </a>
        <p class="text-sm leading-relaxed mb-5" style="color: var(--color-text-secondary);">
          Forney's go-to smoke and vape shop. We carry the hottest flavors, top brands, and widest selection — with great vibes every time.
        </p>
        <!-- Social Links -->
        <div class="flex items-center gap-2">
          <a
            href="https://www.instagram.com/puffparadiseforney/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-lg transition-colors duration-150"
            style="background-color: var(--color-border); color: var(--color-text-secondary);"
            aria-label="Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/61587326453733/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-lg transition-colors duration-150"
            style="background-color: var(--color-border); color: var(--color-text-secondary);"
            aria-label="Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="https://www.tiktok.com/@puffparadiseforney"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-lg transition-colors duration-150"
            style="background-color: var(--color-border); color: var(--color-text-secondary);"
            aria-label="TikTok"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
              <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-primary);">Quick Links</h3>
        <ul class="flex flex-col gap-2">
          {[
            { href: `${base}/`, label: 'Home' },
            { href: `${base}/about`, label: 'About Us' },
            { href: `${base}/contact`, label: 'Contact' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-sm no-underline transition-colors duration-150 hover:text-primary" style="color: var(--color-text-secondary);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-primary);">Contact</h3>
        <ul class="flex flex-col gap-3">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4 mt-0.5 shrink-0" style="color: var(--color-primary);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="text-sm" style="color: var(--color-text-secondary);">
              16383 FM 548, Suite 112<br />Forney, TX 75216
            </span>
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4 shrink-0" style="color: var(--color-primary);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <a href="tel:+19369001762" class="text-sm no-underline hover:text-primary transition-colors" style="color: var(--color-text-secondary);">(936) 900-1762</a>
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-primary);">Hours</h3>
        <ul class="flex flex-col gap-2">
          {[
            { day: 'Monday – Friday', hours: '9:00 AM – 10:00 PM' },
            { day: 'Saturday', hours: '9:00 AM – 10:00 PM' },
            { day: 'Sunday', hours: '9:00 AM – 10:00 PM' },
          ].map(item => (
            <li class="flex justify-between gap-4 text-sm">
              <span style="color: var(--color-text-secondary);">{item.day}</span>
              <span class="font-medium" style="color: var(--color-text-primary);">{item.hours}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 border-t" style="border-color: var(--color-border);">
      <p class="text-xs" style="color: var(--color-text-secondary);">
        &copy; {currentYear} Puff Paradise Smoke & Vape. All rights reserved.
      </p>
      <p class="text-xs" style="color: var(--color-text-disabled);">
        16383 FM 548, Suite 112, Forney, TX 75216
      </p>
    </div>
  </div>
</footer>
